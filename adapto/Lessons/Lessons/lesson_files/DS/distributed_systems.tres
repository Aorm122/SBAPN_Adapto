[sub_resource type="Resource" id="Resource_ai_dis1"]
script = ExtResource("1_7hrog")
id = "AI_DIS1"
term = "Distributed System"
keyword = "multiple computers"
definition = "A system where components are located on different networked computers, which communicate and coordinate their actions by passing messages to achieve a common goal."
simple_terms = "Computers working together over a network."
examples = ["The World Wide Web", "Online multiplayer games"]
difficulty = 1
related_to = ["Networking", "Concurrency"]
tof_statement = {
"false": "A distributed system is a single, monolithic program running on one machine.", 
"true": "A distributed system involves independent components interacting over a network."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis2"]
script = ExtResource("1_7hrog")
id = "AI_DIS2"
term = "Node"
keyword = "computer"
definition = "An individual computer or process within a distributed system that can perform computations and communicate with other nodes."
simple_terms = "A single computer in the group."
examples = ["A web server in a cluster", "A client machine accessing a distributed database"]
difficulty = 1
related_to = ["Distributed System"]
tof_statement = {
"false": "A node in a distributed system refers to the network cable connecting the computers.", 
"true": "Each computer participating in a distributed system can be considered a node."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis3"]
script = ExtResource("1_7hrog")
id = "AI_DIS3"
term = "Communication Middleware"
keyword = "message passing"
definition = "Software that facilitates communication between different nodes in a distributed system, abstracting away network complexities."
simple_terms = "The messenger service between computers."
examples = ["Message Queues (e.g., RabbitMQ, Kafka)", "Remote Procedure Call (RPC) frameworks"]
difficulty = 2
related_to = ["Distributed System", "Networking", "APIs"]
tof_statement = {
"false": "Middleware is a type of hardware component that directly processes data.", 
"true": "Middleware helps different parts of a distributed system talk to each other."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis4"]
script = ExtResource("1_7hrog")
id = "AI_DIS4"
term = "Client-Server Model"
keyword = "request-response"
definition = "A common distributed system architecture where clients request services from a central server, which processes the requests and sends back responses."
simple_terms = "One computer asks, another answers."
examples = ["Web browsing (browser is client, web server is server)", "Email clients connecting to mail servers"]
difficulty = 1
related_to = ["Distributed System", "Networking"]
tof_statement = {
"false": "The server in a client-server model always initiates the communication.", 
"true": "In a client-server model, the client initiates communication by sending a request."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis5"]
script = ExtResource("1_7hrog")
id = "AI_DIS5"
term = "Peer-to-Peer (P2P) Model"
keyword = "equal roles"
definition = "An architecture where nodes act as both clients and servers, sharing resources and responsibilities without a central authority."
simple_terms = "Everyone is both a client and a server."
examples = ["BitTorrent", "Cryptocurrencies (e.g., Bitcoin)"]
difficulty = 2
related_to = ["Distributed System", "Decentralization"]
tof_statement = {
"false": "A P2P system requires a dedicated central server for all operations.", 
"true": "In a P2P system, each node can provide services to other nodes."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis6"]
script = ExtResource("1_7hrog")
id = "AI_DIS6"
term = "Concurrency"
keyword = "simultaneous execution"
definition = "The ability of different parts of a program or system to be executed out-of-order or in parallel, without affecting the final outcome."
simple_terms = "Doing many things at once."
examples = ["Multiple users accessing a website simultaneously", "Parallel processing in a multi-core CPU"]
difficulty = 2
related_to = ["Distributed System", "Parallelism", "Multithreading"]
tof_statement = {
"false": "Concurrency means tasks must complete in a strict sequential order.", 
"true": "Concurrency allows multiple tasks to make progress over a period of time."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis7"]
script = ExtResource("1_7hrog")
id = "AI_DIS7"
term = "Parallelism"
keyword = "simultaneously executing"
definition = "The simultaneous execution of multiple computations. This is a hardware concept typically involving multiple processing units."
simple_terms = "Doing many things at the exact same instant."
examples = ["Using multiple CPU cores to speed up a computation", "Graphics processing units (GPUs) for parallel rendering"]
difficulty = 2
related_to = ["Concurrency", "Multiprocessing"]
tof_statement = {
"false": "Parallelism can be achieved with a single CPU core by interleaving tasks.", 
"true": "Parallelism requires multiple processing units to execute tasks simultaneously."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis8"]
script = ExtResource("1_7hrog")
id = "AI_DIS8"
term = "Race Condition"
keyword = "unpredictable outcome"
definition = "A flaw in a system where the outcome depends on the unpredictable timing of concurrent operations, leading to incorrect results."
simple_terms = "When the order of operations matters and causes errors."
examples = ["Two threads trying to update a shared counter simultaneously", "A process reading a file while another is deleting it"]
difficulty = 3
related_to = ["Concurrency", "Synchronization"]
tof_statement = {
"false": "Race conditions are a problem only in single-threaded applications.", 
"true": "Race conditions occur when the result of concurrent operations is sensitive to their execution order."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis9"]
script = ExtResource("1_7hrog")
id = "AI_DIS9"
term = "Deadlock"
keyword = "waiting indefinitely"
definition = "A situation where two or more processes are blocked forever, each waiting for a resource that is held by another process in the group."
simple_terms = "Everyone is waiting for someone else, and no one can move."
examples = ["Process A holds Resource X and needs Resource Y; Process B holds Resource Y and needs Resource X.", "Two threads waiting for each other's locks."]
difficulty = 3
related_to = ["Concurrency", "Resource Management"]
tof_statement = {
"false": "Deadlocks can be solved by simply restarting one of the involved processes.", 
"true": "A deadlock occurs when a set of processes are stuck waiting for each other to release resources."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis10"]
script = ExtResource("1_7hrog")
id = "AI_DIS10"
term = "Mutual Exclusion"
keyword = "exclusive access"
definition = "A property of concurrency control that ensures that no two concurrent processes can be in their critical section at the same time."
simple_terms = "Only one person can use something at a time."
examples = ["Using locks to protect shared data", "Semaphores for controlling access to a limited resource"]
difficulty = 2
related_to = ["Concurrency", "Synchronization"]
tof_statement = {
"false": "Mutual exclusion allows multiple processes to modify the same data concurrently.", 
"true": "Mutual exclusion is used to prevent simultaneous access to shared resources."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis11"]
script = ExtResource("1_7hrog")
id = "AI_DIS11"
term = "Synchronization"
keyword = "coordination"
definition = "The coordination of concurrent processes or threads to ensure they execute in a specific order or access shared resources safely."
simple_terms = "Making sure processes work together correctly."
examples = ["Using mutexes to protect critical sections", "Event signaling between threads"]
difficulty = 2
related_to = ["Concurrency", "Mutual Exclusion", "Race Condition"]
tof_statement = {
"false": "Synchronization is primarily concerned with increasing the speed of computation.", 
"true": "Synchronization mechanisms are essential for managing concurrent access to shared resources."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis12"]
script = ExtResource("1_7hrog")
id = "AI_DIS12"
term = "Message Passing"
keyword = "sending messages"
definition = "A fundamental communication paradigm in distributed systems where processes exchange information by sending and receiving messages over a network."
simple_terms = "Computers talk by sending letters (messages)."
examples = ["Using sockets for network communication", "Inter-process communication (IPC) mechanisms"]
difficulty = 1
related_to = ["Distributed System", "Networking", "Communication Middleware"]
tof_statement = {
"false": "Message passing relies on shared memory for all communication.", 
"true": "Message passing involves explicit sending and receiving of data between processes."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis13"]
script = ExtResource("1_7hrog")
id = "AI_DIS13"
term = "Remote Procedure Call (RPC)"
keyword = "remote function call"
definition = "A protocol that allows a program on one computer to execute a procedure (subroutine) on another computer without the programmer explicitly coding the details of the remote interaction."
simple_terms = "Calling a function on another computer like it's local."
examples = ["gRPC", "SOAP"]
difficulty = 2
related_to = ["Distributed System", "Message Passing", "APIs"]
tof_statement = {
"false": "RPC requires the programmer to manually handle network socket programming.", 
"true": "RPC allows developers to invoke functions residing on remote machines as if they were local."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis14"]
script = ExtResource("1_7hrog")
id = "AI_DIS14"
term = "Consistency"
keyword = "data agreement"
definition = "The property that ensures all nodes in a distributed system have the same view of data at any given time, or that updates are propagated correctly."
simple_terms = "Everyone sees the same data."
examples = ["Strong Consistency: All reads see the latest write.", "Eventual Consistency: Reads might see stale data temporarily."]
difficulty = 3
related_to = ["Distributed System", "Data Management", "Replication"]
tof_statement = {
"false": "Consistency is only a concern for single-machine systems.", 
"true": "Consistency in a distributed system refers to how up-to-date the data is across different nodes."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis15"]
script = ExtResource("1_7hrog")
id = "AI_DIS15"
term = "Replication"
keyword = "copying data"
definition = "The process of storing multiple copies of data on different nodes in a distributed system to improve availability, fault tolerance, and performance."
simple_terms = "Making copies of data on different computers."
examples = ["Database replication for redundancy", "Caching data on multiple servers"]
difficulty = 2
related_to = ["Distributed System", "Consistency", "Fault Tolerance"]
tof_statement = {
"false": "Replication is used to reduce the amount of storage space needed.", 
"true": "Replication involves creating and maintaining multiple copies of data across different locations."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis16"]
script = ExtResource("1_7hrog")
id = "AI_DIS16"
term = "Fault Tolerance"
keyword = "handling failures"
definition = "The ability of a distributed system to continue operating correctly even when one or more of its components fail."
simple_terms = "Keeps working even if parts break."
examples = ["Redundant servers that take over if one fails", "Error detection and correction mechanisms"]
difficulty = 2
related_to = ["Distributed System", "Availability", "Replication"]
tof_statement = {
"false": "Fault tolerance means the system will never experience any failures.", 
"true": "A fault-tolerant system can withstand component failures without significant disruption."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis17"]
script = ExtResource("1_7hrog")
id = "AI_DIS17"
term = "Availability"
keyword = "uptime"
definition = "The probability that a system is operational and accessible when it is needed for use."
simple_terms = "How often the system is up and running."
examples = ["Achieving 99.999% uptime for a critical service", "Minimizing downtime during maintenance"]
difficulty = 2
related_to = ["Distributed System", "Fault Tolerance"]
tof_statement = {
"false": "A system with high availability is immune to all types of failures.", 
"true": "High availability means the system is accessible and operational most of the time."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis18"]
script = ExtResource("1_7hrog")
id = "AI_DIS18"
term = "Scalability"
keyword = "handling growth"
definition = "The ability of a distributed system to handle an increasing amount of work or users by adding resources."
simple_terms = "Can handle more users/data by adding more computers."
examples = ["Adding more web servers to handle increased traffic", "Horizontal scaling by adding more machines"]
difficulty = 2
related_to = ["Distributed System", "Performance"]
tof_statement = {
"false": "Scalability only refers to increasing the power of a single machine.", 
"true": "Scalability allows a system to grow its capacity to meet increasing demand."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis19"]
script = ExtResource("1_7hrog")
id = "AI_DIS19"
term = "Load Balancing"
keyword = "distributing traffic"
definition = "The process of distributing incoming network traffic across multiple servers to ensure no single server becomes overwhelmed, improving responsiveness and availability."
simple_terms = "Spreading the work evenly among servers."
examples = ["Using a load balancer to route requests to available web servers", "Round-robin, Least Connections, IP Hash algorithms"]
difficulty = 2
related_to = ["Scalability", "Availability", "Networking"]
tof_statement = {
"false": "Load balancing is only effective when there is a single server handling all traffic.", 
"true": "Load balancing helps prevent server overload by distributing requests."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis20"]
script = ExtResource("1_7hrog")
id = "AI_DIS20"
term = "CAP Theorem"
keyword = "consistency, availability, partition tolerance"
definition = "A theorem stating that it is impossible for a distributed data store to simultaneously provide more than two out of the following three guarantees: Consistency, Availability, and Partition Tolerance."
simple_terms = "You can only have two out of three: consistency, availability, or partition tolerance."
examples = ["A system prioritizing Consistency and Availability might sacrifice Partition Tolerance.", "A system prioritizing Availability and Partition Tolerance might sacrifice strong Consistency."]
difficulty = 3
related_to = ["Distributed System", "Consistency", "Availability", "Networking"]
tof_statement = {
"false": "The CAP theorem states that all three properties (Consistency, Availability, Partition Tolerance) can always be achieved simultaneously.", 
"true": "The CAP theorem dictates trade-offs between Consistency, Availability, and Partition Tolerance in distributed systems."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis21"]
script = ExtResource("1_7hrog")
id = "AI_DIS21"
term = "Partition Tolerance"
keyword = "network failure"
definition = "The ability of a distributed system to continue operating despite network partitions, where communication between nodes is disrupted."
simple_terms = "Works even if the network breaks."
examples = ["A system that can function even if some servers can't talk to others.", "Data replication across different data centers."]
difficulty = 2
related_to = ["CAP Theorem", "Distributed System", "Networking"]
tof_statement = {
"false": "Partition tolerance means the system can operate without any network connection at all.", 
"true": "Partition tolerance ensures a distributed system can operate even when network links fail."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis22"]
script = ExtResource("1_7hrog")
id = "AI_DIS22"
term = "Leader Election"
keyword = "choosing a leader"
definition = "The process by which nodes in a distributed system agree on a single node to act as a leader or coordinator for a specific task."
simple_terms = "Deciding which computer is in charge."
examples = ["Paxos or Raft algorithms for consensus", "A primary replica in a replicated database"]
difficulty = 3
related_to = ["Distributed System", "Consensus", "Fault Tolerance"]
tof_statement = {
"false": "Leader election is only necessary in systems with a single node.", 
"true": "Leader election is used to designate a single node to perform a critical role in a distributed system."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis23"]
script = ExtResource("1_7hrog")
id = "AI_DIS23"
term = "Consensus"
keyword = "agreement"
definition = "A process in a distributed system by which a group of nodes agree on a single value or decision, even in the presence of failures."
simple_terms = "Getting everyone to agree on something."
examples = ["Distributed databases agreeing on transaction commits", "Distributed locking services"]
difficulty = 4
related_to = ["Distributed System", "Leader Election", "Fault Tolerance"]
tof_statement = {
"false": "Consensus is easily achieved in distributed systems without complex algorithms.", 
"true": "Consensus algorithms help distributed systems reach agreement despite potential failures."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis24"]
script = ExtResource("1_7hrog")
id = "AI_DIS24"
term = "Distributed Transaction"
keyword = "transaction across multiple nodes"
definition = "A transaction that operates on data spread across multiple distinct nodes or systems in a distributed environment."
simple_terms = "A single operation that affects data on multiple computers."
examples = ["Two-Phase Commit (2PC) protocol", "Atomically transferring funds between bank accounts across different systems."]
difficulty = 4
related_to = ["Distributed System", "ACID Properties", "Consistency"]
tof_statement = {
"false": "Distributed transactions are simpler to implement than single-node transactions.", 
"true": "Distributed transactions ensure atomicity for operations spanning multiple nodes."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis25"]
script = ExtResource("1_7hrog")
id = "AI_DIS25"
term = "ACID Properties"
keyword = "atomicity, consistency, isolation, durability"
definition = "A set of properties that guarantee reliable processing of database transactions: Atomicity, Consistency, Isolation, and Durability."
simple_terms = "Rules for reliable data changes: All or nothing, Correct data, No interference, Lasting changes."
examples = ["Atomicity: All parts of a transaction succeed or none do.", "Durability: Committed data is permanently saved."]
difficulty = 3
related_to = ["Distributed Transaction", "Database Systems", "Consistency"]
tof_statement = {
"false": "Isolation in ACID properties allows concurrent transactions to interfere with each other.", 
"true": "ACID properties ensure that database transactions are processed reliably."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis26"]
script = ExtResource("1_7hrog")
id = "AI_DIS26"
term = "Eventual Consistency"
keyword = "eventually consistent"
definition = "A consistency model where, if no new updates are made to a given data item, eventually all accesses to that item will return the last updated value."
simple_terms = "Data will be the same everywhere, but it might take time."
examples = ["DNS propagation", "Social media feeds updating across devices"]
difficulty = 3
related_to = ["Consistency", "Distributed System", "Availability"]
tof_statement = {
"false": "Eventually consistent systems guarantee that all reads will immediately reflect the latest write.", 
"true": "In an eventually consistent system, all replicas will converge to the same state over time."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis27"]
script = ExtResource("1_7hrog")
id = "AI_DIS27"
term = "Strong Consistency"
keyword = "immediate consistency"
definition = "A consistency model where any read operation is guaranteed to return the value of the most recent write operation."
simple_terms = "Everyone sees the newest data right away."
examples = ["Traditional relational databases with a single master", "Systems using strict two-phase commit"]
difficulty = 3
related_to = ["Consistency", "Distributed System", "ACID Properties"]
tof_statement = {
"false": "Strong consistency is always achievable without any performance trade-offs.", 
"true": "Strong consistency ensures that all clients see the same data in the same order."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis28"]
script = ExtResource("1_7hrog")
id = "AI_DIS28"
term = "Network Partition"
keyword = "split network"
definition = "A situation where a network failure causes a distributed system to be divided into two or more segments, where nodes within a segment can communicate but nodes in different segments cannot."
simple_terms = "The network breaks into separate pieces."
examples = ["A router failure isolating one data center from another.", "A fiber cut affecting communication between two geographical regions."]
difficulty = 2
related_to = ["Distributed System", "Partition Tolerance", "Networking"]
tof_statement = {
"false": "A network partition only affects a single node in the system.", 
"true": "A network partition prevents communication between different parts of a distributed system."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis29"]
script = ExtResource("1_7hrog")
id = "AI_DIS29"
term = "Idempotence"
keyword = "repeatable effect"
definition = "The property of an operation where applying it multiple times has the same effect as applying it once."
simple_terms = "Doing it again has no extra effect."
examples = ["Setting a value: `x = 5` can be done multiple times.", "A payment processing request that only charges once even if sent multiple times."]
difficulty = 3
related_to = ["Distributed System", "Reliability", "Message Passing"]
tof_statement = {
"false": "Idempotence means an operation must complete successfully on the first attempt.", 
"true": "An idempotent operation can be safely retried without unintended side effects."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis30"]
script = ExtResource("1_7hrog")
id = "AI_DIS30"
term = "Distributed Hash Table (DHT)"
keyword = "distributed key-value store"
definition = "A decentralized distributed system that provides a lookup service similar to a hash table: key-value pairs are stored in a distributed manner."
simple_terms = "A shared dictionary spread across many computers."
examples = ["Chord, Kademlia (used in BitTorrent)", "Amazon DynamoDB uses DHT principles"]
difficulty = 3
related_to = ["Distributed System", "Decentralization", "Key-Value Store"]
tof_statement = {
"false": "DHTs require a central server to manage all key-value mappings.", 
"true": "DHTs distribute key-value data across a network of nodes."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis31"]
script = ExtResource("1_7hrog")
id = "AI_DIS31"
term = "Byzantine Fault Tolerance"
keyword = "malicious actors"
definition = "The property of a distributed system that allows it to continue operating correctly even when some nodes behave arbitrarily or maliciously (Byzantine faults)."
simple_terms = "Works even if some computers are actively trying to break it."
examples = ["Blockchain networks (e.g., Bitcoin's Proof-of-Work)", "Some distributed databases requiring high security"]
difficulty = 4
related_to = ["Distributed System", "Fault Tolerance", "Consensus"]
tof_statement = {
"false": "Byzantine fault tolerance is only concerned with nodes crashing or becoming unresponsive.", 
"true": "Byzantine fault tolerance is crucial for systems where nodes might act maliciously."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis32"]
script = ExtResource("1_7hrog")
id = "AI_DIS32"
term = "Gossip Protocol"
keyword = "randomized communication"
definition = "A communication protocol used in distributed systems where nodes periodically exchange information with a random subset of other nodes, spreading information efficiently."
simple_terms = "Spreading information by randomly telling neighbors."
examples = ["Anti-entropy protocols", "Membership management in large clusters"]
difficulty = 3
related_to = ["Distributed System", "Message Passing", "Scalability"]
tof_statement = {
"false": "Gossip protocols require a central server to coordinate information spread.", 
"true": "Gossip protocols are efficient for disseminating information across large distributed systems."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis33"]
script = ExtResource("1_7hrog")
id = "AI_DIS33"
term = "State Machine Replication"
keyword = "replicated state machine"
definition = "A technique for building fault-tolerant distributed systems where each replica maintains an identical state and processes incoming requests in the same order."
simple_terms = "Making sure all copies of a system's data follow the same steps."
examples = ["Raft consensus algorithm", "Paxos"]
difficulty = 4
related_to = ["Distributed System", "Fault Tolerance", "Consensus", "Consistency"]
tof_statement = {
"false": "State machine replication is only applicable to systems that do not require fault tolerance.", 
"true": "State machine replication ensures that all replicas of a service behave identically."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis34"]
script = ExtResource("1_7hrog")
id = "AI_DIS34"
term = "Message Queue"
keyword = "asynchronous communication"
definition = "A form of asynchronous service-to-service communication where messages are sent from a producer to a queue, and consumed by a consumer."
simple_terms = "A waiting line for messages between programs."
examples = ["RabbitMQ", "Apache Kafka", "Amazon SQS"]
difficulty = 2
related_to = ["Distributed System", "Communication Middleware", "Asynchronous Processing"]
tof_statement = {
"false": "Message queues require the producer and consumer to be online simultaneously.", 
"true": "Message queues enable decoupled and asynchronous communication between services."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis35"]
script = ExtResource("1_7hrog")
id = "AI_DIS35"
term = "Service Discovery"
keyword = "finding services"
definition = "The process by which a service in a distributed system automatically finds the network location of other services it needs to interact with."
simple_terms = "How services find each other on the network."
examples = ["Consul", "etcd", "Zookeeper"]
difficulty = 3
related_to = ["Distributed System", "Microservices", "Networking"]
tof_statement = {
"false": "Service discovery is only needed in monolithic applications.", 
"true": "Service discovery helps services locate each other dynamically in a distributed environment."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis36"]
script = ExtResource("1_7hrog")
id = "AI_DIS36"
term = "Circuit Breaker Pattern"
keyword = "preventing cascading failures"
definition = "A design pattern used to detect failures and prevent a complex distributed system from becoming completely unresponsive by stopping repeated calls to a failing service."
simple_terms = "Like an electrical circuit breaker, stops bad requests from spreading."
examples = ["Netflix Hystrix", "Resilience4j"]
difficulty = 3
related_to = ["Distributed System", "Fault Tolerance", "Microservices"]
tof_statement = {
"false": "A circuit breaker permanently disables a service once it fails.", 
"true": "The circuit breaker pattern protects a system from cascading failures by temporarily stopping calls to a known-failing service."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis37"]
script = ExtResource("1_7hrog")
id = "AI_DIS37"
term = "Idempotent Operation"
keyword = "repeatable effect"
definition = "An operation that can be applied multiple times without changing the result beyond the initial application. Crucial for reliable distributed systems."
simple_terms = "Repeating the action has no additional effect."
examples = ["Setting a variable to a specific value: `x = 10`.", "A `DELETE` request to a specific resource."]
difficulty = 3
related_to = ["Distributed System", "Reliability", "Message Passing"]
tof_statement = {
"false": "An operation is idempotent if it always succeeds on the first try.", 
"true": "Idempotent operations allow for safe retries in case of network issues or failures."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis38"]
script = ExtResource("1_7hrog")
id = "AI_DIS38"
term = "Distributed Locking"
keyword = "coordinate access"
definition = "A mechanism to ensure that only one process or thread across multiple nodes in a distributed system can access a shared resource at any given time."
simple_terms = "A lock that works across many computers."
examples = ["ZooKeeper for distributed locks", "Redis-based distributed locks"]
difficulty = 3
related_to = ["Distributed System", "Mutual Exclusion", "Consensus"]
tof_statement = {
"false": "Distributed locks are only necessary for local resources within a single machine.", 
"true": "Distributed locking is used to manage exclusive access to shared resources across different nodes."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis39"]
script = ExtResource("1_7hrog")
id = "AI_DIS39"
term = "Time Synchronization"
keyword = "consistent time"
definition = "The process of ensuring that clocks across different nodes in a distributed system are closely aligned, which is critical for logging, ordering events, and debugging."
simple_terms = "Making sure all computers have the same time."
examples = ["Network Time Protocol (NTP)", "Protocol for Atomic Clocks (PAC)"]
difficulty = 2
related_to = ["Distributed System", "Event Ordering", "Networking"]
tof_statement = {
"false": "Time synchronization is irrelevant in distributed systems as each node has its own clock.", 
"true": "Accurate time synchronization is important for ordering events in distributed systems."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_dis40"]
script = ExtResource("1_7hrog")
id = "AI_DIS40"
term = "Distributed Tracing"
keyword = "request flow"
definition = "A method used to profile and monitor requests as they travel through distributed system components, helping to identify bottlenecks and errors."
simple_terms = "Tracking a request as it goes through different services."
examples = ["Jaeger", "Zipkin", "OpenTelemetry"]
difficulty = 3
related_to = ["Distributed System", "Observability", "Performance"]
tof_statement = {
"false": "Distributed tracing is only useful for debugging single-process applications.", 
"true": "Distributed tracing helps understand the path and timing of requests across multiple services."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

